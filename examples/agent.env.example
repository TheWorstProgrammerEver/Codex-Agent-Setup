# Copy this file to ../agent.env and edit local values there.
# Do not commit private keys, tokens, passwords, recovery codes, or Codex auth.

SKILLS_REPO_URL="https://github.com/TheWorstProgrammerEver/codex-skills.git"
SKILLS_REF="main"

# Intended target: AGENT_USER@AGENT_HOSTNAME.local.
# AGENT_NAME is the durable agent identity; AGENT_USER is the local host user.
# The local user should already exist before setup runs.
AGENT_NAME="my-agent"
AGENT_HOSTNAME="$AGENT_NAME"
AGENT_USER="my-user"

# Optional public SSH key material for workstation access.
WORKSTATION_PUBLIC_KEY=""
WORKSTATION_PUBLIC_KEY_FILE=""

# Enable only for a dedicated Codex-managed host.
ENABLE_PASSWORDLESS_SUDO=0

# Keep password auth enabled until public-key login is confirmed.
DISABLE_PASSWORD_AUTH=0

# Set SKIP_CODEX_LOGIN=1 when staging packages/skills without logging in.
SKIP_CODEX_LOGIN=0

# Set RUN_CODEX_BOOTSTRAP=0 when staging packages/skills without running Codex bootstrap.
RUN_CODEX_BOOTSTRAP=1

# Workspace to mark trusted in ~/.codex/config.toml.
CODEX_WORKSPACE="$HOME"

# Shared AGENTS.md managed block source. Keep the default pointed at the
# source-controlled shared durable notes repo unless testing a local file.
SHARED_AGENT_GUIDANCE_REF="main"
SHARED_AGENT_GUIDANCE_URL=""
SHARED_AGENT_GUIDANCE_FILE=""

# Advanced overrides.
NODE_DIST_INDEX_URL="https://nodejs.org/dist/index.json"
NODE_DIST_BASE_URL="https://nodejs.org/dist"
NODE_LTS_PREFIX="/opt/node-lts"
# Leave empty to track the latest official LTS line. Set to a major version, such as 24, only for a deliberate pin.
NODE_LTS_LINE=""
NODE_LTS_FORCE=0
CODEX_NPM_PACKAGE="@openai/codex"
CODEX_INSTALL_FORCE=0
AGENT_BOOTSTRAP_SKILLS_DIR="$HOME/agent-bootstrap-skills"
SKILLS_INSTALL_TARGET="$HOME/.codex/skills"
